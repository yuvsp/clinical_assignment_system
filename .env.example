# Optional: copy to .env and set values
# DATABASE_URL=sqlite:///clinical_assignment.db
# SECRET_KEY=your-secret-key
# FLASK_DEBUG=0
# SESSION_PERMANENT=false

# Gmail API OAuth2 (for sending rich student assignment emails)
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:5000/api/gmail/callback
#
# For production, set GOOGLE_REDIRECT_URI to your deployed callback URL
# and keep SECRET_KEY stable so stored Gmail tokens remain decryptable.
#
# OAuth consent screen must include gmail.send + gmail.metadata (see README).
